export XDG_SESSION_TYPE=x11

X11_CONFIG_DIR=~/.config/wm

nvidia-settings --config=${X11_CONFIG_DIR}/nvidia-settings-rc -l
chlayout gaming
xinput set-prop "Compx 2.4G Wireless Receiver" "libinput Accel Profile Enabled" 0 1 0
xinput set-prop "Compx 2.4G Wireless Receiver" "libinput Accel Speed" -0.75
xset -dpms
xset s off
xset r rate 300 50

exec xbindkeys -f ${X11_CONFIG_DIR}/xbindkeysrc -n
