#!/usr/bin/env sh

dotfiles="$1"
host="$2"

if [ "$dotfiles" = "" ]; then
	echo "pass a dotfiles directory and a host name"
	exit 1
fi

if [ "$host" = "" ]; then
	echo "pass a host name"
	exit 1
fi

newscript archconf <<EOF
#!/usr/bin/env sh

cd $dotfiles
exec nvim ./configuration-$host.sh
EOF

newscript archupd <<EOF
#!/usr/bin/env sh

if [ "\$1" = 'upgrade' ]; then
	paru -Syu
fi

cd $dotfiles
./configuration-$host.sh

if [ "\$1" = 'upgrade' ]; then
	sudo mkinitcpio -P
	sudo locale-gen
	sudo bootctl update
fi
EOF

newscript archexport <<EOF
#!/usr/bin/env sh

echo "\$(paru -Qe | cut -d ' ' -f 1)" > $dotfiles/packages-$host
EOF

newscript archgit <<EOF
#!/usr/bin/env sh

cd $dotfiles
lazygit
EOF
