#!/usr/bin/env sh
set -e

usage() {
	cat <<EOF
Example: config $DOTFILES_MODULE_NAME
EOF
}
usage_err() {
	if ! [ "$1" = "" ]; then
		echo "$1" >&2
	fi
	usage
	exit 1
}

while [ $# -gt 0 ]; do
	case $1 in
		*)
			usage_err "Invalid option: $1"
			;;
	esac
	shift
done
dotfiles="$DOTFILES_DIR"
host="$DOTFILES_HOST"

newscript archconf <<EOF
#!/usr/bin/env sh

cd $dotfiles
exec \$EDITOR ./configuration-$host.sh
EOF

newscript archupd <<EOF
#!/usr/bin/env sh

usage() {
	echo "Example: \$(basename \$0) [--upgrade|-u] [--module|-m MODULE_NAME]"
}
usage_err() {
	[ "\$1" ] && echo "\$1" >&2
	usage
	exit 1
}

while [ \$# -gt 0 ]; do
	case \$1 in
		--upgrade|-u)
			upgrade=1
			;;
		--module|-m)
			[ "\$2" = "" ] && usage_err "Argument not specified"
			module="\$2"
			shift
			;;
		*)
			usage_err "Invalid option: \$1"
			;;
	esac
	shift
done

[ "\$upgrade" = 1 ] && $DOTFILES_AUR_HELPER -Syu

cd $dotfiles
[ "\$module" = "" ] && ./configuration-$host.sh || ./configuration-$host.sh --module \$module

if [ "\$upgrade" = 1 ]; then
	sudo mkinitcpio -P
	sudo locale-gen
	sudo bootctl update
	sudo hwclock --systohc
	command -v sbctl >/dev/null 2>&1 && sudo sbctl sign-all
fi
EOF

newscript archexport <<EOF
#!/usr/bin/env sh

echo "\$($DOTFILES_AUR_HELPER -Qe | cut -d ' ' -f 1)" > $dotfiles/packages-$host
EOF

newscript archgit <<EOF
#!/usr/bin/env sh

cd $dotfiles
lazygit
EOF

newscript archclean <<EOF
#!/usr/bin/env sh

orphans="\$($DOTFILES_AUR_HELPER -Qdtq | xargs)"
if [ ! "\$orphans" = "" ]; then
	$DOTFILES_AUR_HELPER -Rs --noconfirm \$orphans
fi
yes | $DOTFILES_AUR_HELPER -Scc
EOF

newscript archedit <<EOF
#!/usr/bin/env sh

if [ "\$EDITOR" = "" ]; then
	EDITOR="nvim"
fi

command="\$(whereis "\$1" | cut -d " " -f 2)"
\$EDITOR "\$command"
EOF

newscript archsync <<'EOF'
#!/usr/bin/env sh

rate-mirrors arch | sudo tee /etc/pacman.d/mirrorlist
EOF

