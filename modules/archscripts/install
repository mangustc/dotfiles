#!/usr/bin/env -S sh -e

dotfiles="$1"
host="$2"

if [ "$dotfiles" = "" ]; then
	echo "pass a dotfiles directory and a host name"
	exit 1
fi

if [ "$host" = "" ]; then
	echo "pass a host name"
	exit 1
fi

newscript archconf <<EOF
#!/usr/bin/env -S sh -e

cd $dotfiles
exec \$EDITOR ./configuration-$host.sh
EOF

newscript archupd <<EOF
#!/usr/bin/env -S sh -e

if [ "\$1" = 'upgrade' ]; then
	paru -Syu
fi

cd $dotfiles
./configuration-$host.sh

if [ "\$1" = 'upgrade' ]; then
	sudo mkinitcpio -P
	sudo locale-gen
	sudo bootctl update
	sudo hwclock --systohc
fi
EOF

newscript archexport <<EOF
#!/usr/bin/env -S sh -e

echo "\$(paru -Qe | cut -d ' ' -f 1)" > $dotfiles/packages-$host
EOF

newscript archgit <<EOF
#!/usr/bin/env -S sh -e

cd $dotfiles
lazygit
EOF

newscript archclean <<EOF
#!/usr/bin/env -S sh -e

orphans="\$(paru -Qdtq | xargs)"
if [ ! "\$orphans" = "" ]; then
	paru -Rs --noconfirm \$orphans
fi
yes | paru -Scc
EOF

newscript archedit <<EOF
#!/usr/bin/env -S sh -e

\$EDITOR "\$(whereis \$1 | cut -d " " -f 2)"
EOF
