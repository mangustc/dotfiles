#!/usr/bin/env sh

config_file="${XDG_CONFIG_HOME}/dotfiles/sysconfupd.conf"
eval "$(cat "${config_file}")"

source_dir="${SOURCE_DIR}"
dest_dir="${DEST_DIR}"
conf_files="${CONF_FILES}"
packages_file="${PACKAGES_FILE}"

copy_conf() {
	file_path="$1"
	out_dir="${dest_dir}$(dirname "$1")"
	mkdir -p "${out_dir}"
	cp -vr "${source_dir}${file_path}" "${out_dir}"
}

save_package_list() {
	echo "Saving pacman package list"
	pacman -Qeq >"${packages_file}"
	if [ ! "$(cat "${packages_file}" | grep "paru-bin-debug")" = "" ]; then
		paru -R paru-bin-debug
		save_package_list
	fi
	if [ ! "$(cat "${packages_file}" | grep "paru-debug")" = "" ]; then
		paru -R paru-debug
		save_package_list
	fi
}

save_sysconf() {
	echo "Saving system configuration"

	if [ "${dest_dir}" = "" ] || [ "${dest_dir}" = "/root" ]; then
		echo "Are you sure '${dest_dir}' is your desired out directory???"
		exit 1
	fi

	rm -rf "${dest_dir}"
	echo "${conf_files}" | while IFS= read -r line; do
		copy_conf ${line}
	done
}

save_package_list
save_sysconf
