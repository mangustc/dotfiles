#!/usr/bin/env sh

home_dirs="${MY_DOTFILES_HOME_DIRS}"

link() {
    file_source="$1"
    file_dest="$2"
    file_source_name="$(basename "${file_source}")"

    if [ -f "${file_source}" ]; then
        return 1
    fi

    if [ "${file_source_name}" = "*" ]; then
        return 1
    fi

    if [ -L "${file_dest}" ]; then
        rm -f "${file_dest}"
    else
        rm -rf "${file_dest}"
    fi
    ln -sv "${file_source}" "${file_dest}"
}

link_dir() {
    for filepath in "$1/$2/*"; do
        filename="$(basename "${filepath}")"

        link "${filepath}" "${HOME}/$2/${filename}"
    done
}

link_home() {
    source_dir="$1"

    link_dir "${source_dir}" ".config"
    link_dir "${source_dir}" ".local/bin"
    link "${source_dir}/.bashrc" "${HOME}/.bashrc"
    link "${source_dir}/.bash_profile" "${HOME}/.bash_profile"

    for filepath in "${source_dir}/usc/local/bin/*"; do
        filename="$(basename "${filepath}")"

        sudo cp -vr "${filepath}" "/usr/local/bin/"
    done
}

echo "${home_dirs}" | while IFS= read -r line; do
    link_home "${MY_DOTFILES_DIR}/${line}"
done
