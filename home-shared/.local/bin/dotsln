#!/usr/bin/env sh

home_dirs="${MY_DOTFILES_HOME_DIRS}"

clear_broken_symlinks() {
    find "$1" -maxdepth 1 -mindepth 1 -type l -xtype l -delete
}

link() {
    file_source="$1"
    file_dest="$2"
    file_source_name="$(basename "${file_source}")"

    if [ ! -f "${file_source}" ] || [ "${file_source_name}" = "" ] || [ "${file_source_name}" = "*" ]; then
        return 1
    fi

    if [ -L "${file_dest}" ]; then
        rm -f "${file_dest}"
    else
        rm -rf "${file_dest}"
    fi

    ln -sv "${file_source}" "${file_dest}"
}
# make find subshell see link function
export -f link

link_dir() {
    find "$1/$2" -maxdepth 1 -mindepth 1 -exec sh -c 'link "$0" "${HOME}/'"$2"'/$(basename "$0")"' {} \;
}

link_home() {
    source_dir="$1"

    clear_broken_symlinks "${HOME}/.config"
    clear_broken_symlinks "${HOME}/.local/bin"
    clear_broken_symlinks "${HOME}"

    link_dir "${source_dir}" ".config"
    link_dir "${source_dir}" ".local/bin"
    link "${source_dir}/.bashrc" "${HOME}/.bashrc"
    link "${source_dir}/.bash_profile" "${HOME}/.bash_profile"
    find "${source_dir}/usr/local/bin" -maxdepth 1 -mindepth 1 -exec sh -c 'sudo cp -vr "$0" "/usr/local/bin"' {} \;
}

echo "${home_dirs}" | while IFS= read -r line; do
    link_home "${MY_DOTFILES_DIR}/${line}"
done
