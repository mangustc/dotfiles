#!/usr/bin/env python

import subprocess
import json
import sys


# Should be formatted as JSON
CONFIG_FILE = "/etc/ebmm.conf"
LABEL_PREFIX = "BOOT-"
LABEL_POSTFIX = "-END"


def run_command(cmd: str) -> (str, int):
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout.strip(), result.returncode


def get_partition_disk_and_num_by_label(boot_partition_label: str) -> (str | None, str | None):
    _output, _ = run_command("lsblk --json -o path,label")
    path = ""
    for device in json.loads(_output).get("blockdevices", []):
        if device.get("label") == boot_partition_label:
            path = device["path"]
            break

    _output, _ = run_command("lsblk --json -o name,path,type,label,partn")
    for disk in json.loads(_output).get("blockdevices", []):
        for child in disk.get("children", []):
            if child.get("path") == path:
                return (disk["path"], child.get("partn"))

    return (None, None)


class BootRecord(object):
    def __init__(self, obj: object):
        self.name = obj['name']
        self.params = obj['params']
        self.initrd = obj['initrd']
        self.loader = obj['loader']

        efi_disk, efi_part = get_partition_disk_and_num_by_label(obj['partition_label'])
        if (efi_part is None) or (efi_disk is None):
            print("No such boot device with label:", self.partition_label)
            sys.exit(1)

        self.efi_disk = efi_disk
        self.efi_part = efi_part

    def create(self):
        result, _ = run_command(f'''sudo efibootmgr --quiet --create --disk "{self.efi_disk}" --part "{self.efi_part}" --label "{LABEL_PREFIX}{self.name}{LABEL_POSTFIX}" --loader "{self.loader}" --unicode "{self.params} initrd={self.initrd}"''')


if __name__ == "__main__":
    contents = ""
    with open(CONFIG_FILE) as f:
        contents = f.read()

    objs = json.loads(contents)

    boots: list[BootRecord] = []
    for obj in objs:
        boots.append(BootRecord(obj))

    efi_bootorder, _ = run_command('''efibootmgr | grep "BootOrder: " | cut -c "12-"''')
    while True:
        existing_entry, _ = run_command(f'''efibootmgr -u | grep -e "{LABEL_PREFIX}" | grep -e "{LABEL_POSTFIX}"''')
        if existing_entry == "":
            break
        efi_hexnum = existing_entry[4:8]
        _, _ = run_command(f'''sudo efibootmgr -B -b {efi_hexnum}''')

    for boot in boots:
        boot.create()

    _, _ = run_command(f'''sudo efibootmgr -qo ${efi_bootorder}''')
